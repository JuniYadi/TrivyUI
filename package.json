{
  "name": "trivyui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "tw:build": "tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/tailwind.generated.css",
    "dev": "bun run db:backfill-tag-groups && bun run tw:build && bun run --hot src/index.ts",
    "start": "bun run --cwd dist index.js",
    "build": "bun run tw:build && rm -rf dist && bun build --target=bun --production --sourcemap --outdir=dist ./src/index.ts",
    "db:seed-dashboard": "bun run scripts/seed-dashboard.ts",
    "db:backfill-tag-groups": "bun run scripts/backfill-image-tag-groups.ts",
    "notify:weekly": "bun run scripts/send-weekly-reminder.ts",
    "notify:monthly": "bun run scripts/send-monthly-stats.ts"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.168.26",
    "chart.js": "^4.5.1",
    "nodemailer": "^8.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.5.0",
    "bun-types": "^1.3.1",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4"
  }
}
