{
  "name": "trivyui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js",
    "build": "rm -rf dist && bun build --target bun src/index.ts --outdir dist && bun build --target browser src/main.tsx --outdir dist && bun run scripts/build-html.ts",
    "db:seed-dashboard": "bun run scripts/seed-dashboard.ts",
    "build:html": "bun run scripts/build-html.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.1",
    "bun-types": "^1.3.1"
  }
}