{
  "name": "trivyui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run --cwd dist index.js",
    "build": "rm -rf dist && bun build --target=bun --production --outdir=dist ./src/index.ts",
    "db:seed-dashboard": "bun run scripts/seed-dashboard.ts"
  },
  "dependencies": {
    "nodemailer": "^8.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.1",
    "bun-types": "^1.3.1"
  }
}